<head>
  <script is:inline>
    (function () {
      const THEMES_AVAILABLE = ["customLight", "customDark"];
      const DEFAULT_THEME = "customLight";
      const DARK_THEME = "customDark";
      let themeToApply = DEFAULT_THEME;
      try {
        const storedTheme = localStorage.getItem("theme");
        if (storedTheme && THEMES_AVAILABLE.includes(storedTheme)) {
          themeToApply = storedTheme;
        } else {
          if (
            window.matchMedia &&
            window.matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            themeToApply = DARK_THEME;
          }
          if (storedTheme && !THEMES_AVAILABLE.includes(storedTheme)) {
            localStorage.removeItem("theme");
          }
        }
      } catch (e) {
        console.warn("localStorage not accessible for theme persistence.");
        if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
        ) {
          themeToApply = DARK_THEME;
        }
      }
      document.documentElement.setAttribute("data-theme", themeToApply);
    })();
  </script>

</head>
