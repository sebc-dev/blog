---
import { useI18n } from '../../lib/i18n/i18nUtils';

const { t } = useI18n(Astro.locals);
---

<footer class="bg-base-200 mt-8" role="contentinfo">
  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Copyright -->
      <div class="text-center md:text-left">
        <p class="text-sm text-base-content/70">
          {t('footer.copyright')}
        </p>
      </div>

      <!-- Built with -->
      <div class="text-center md:text-right">
        <p class="text-sm text-base-content/70">
          {t('footer.builtWith')}
          <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="link link-hover text-primary">
            Astro
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
